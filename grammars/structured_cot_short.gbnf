root ::= ws "{" ws thought "," ws answer ws "}" ws

thought ::= "\"thought\"" ws ":" ws string
answer ::= "\"answer\"" ws ":" ws string

string ::= "\"" chars "\""
chars ::= char*
char ::= [^"\\\x7F\x00-\x1F] | "\\" escape
escape ::= ["\\/bfnrt] | "u" hex hex hex hex
hex ::= [0-9a-fA-F]
ws ::= [ \t\n\r]*
